<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Mentoria Hub</title>
    <meta
      name="description"
      content="Mentoria Hub helps students find competitions, scholarships, internships, summer schools, and other educational opportunities."
    >
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='6' fill='%2307131e'/%3E%3Cpath d='M7 20V8h4l5 7 5-7h4v16h-4V14l-5 7-5-7v10H7Z' fill='%2311c6cf'/%3E%3C/svg%3E">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700;800&family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="styles.css">
  </head>
  <body>
    <main>
      <section class="hero" aria-labelledby="hero-title">
        <div class="grain" aria-hidden="true"></div>
        <svg class="ethno-route" viewBox="0 0 180 760" aria-hidden="true" focusable="false">
          <path d="M92 14 C24 98 144 174 72 260 C12 332 128 414 80 500 C36 580 116 640 66 734" />
          <circle cx="92" cy="14" r="6" />
          <circle cx="72" cy="260" r="6" />
          <circle cx="80" cy="500" r="6" />
          <circle cx="66" cy="734" r="6" />
        </svg>

        <div class="hero-inner">
          <nav class="hero-rail" aria-label="Mentoria Hub sections">
            <a class="wordmark" href="#hero-title" aria-label="Mentoria Hub home">Mentoria Hub</a>
            <div class="rail-links">
              <a href="#features">Matches</a>
              <a href="#courses">Courses</a>
              <a href="#companion">MentorPet</a>
              <a href="#mentors">Mentors</a>
            </div>
          </nav>

          <div class="hero-grid">
            <div class="hero-copy">
              <p class="eyebrow">Opportunity intelligence / grades 8-11</p>
              <h1 id="hero-title">Mentoria Hub</h1>
              <p class="promise">With you on your way to your dream</p>
              <div class="keyword-band" aria-label="Mentoria Hub learning and opportunity areas">
                <span>SAT</span>
                <span>IELTS</span>
                <span>Courses</span>
                <span>Opportunity Search</span>
              </div>
              <p class="all-in-one">.. all in one place</p>
              <p class="hero-lede">
                Find competitions, scholarships, internships, and summer schools that fit your profile, then keep learning through Mentoria's own SAT, IELTS, and subject courses.
              </p>
              <div class="hero-actions">
                <a class="button button-primary" href="#match-console">
                  <span>Start your journey</span>
                  <span class="button-mark" aria-hidden="true">></span>
                </a>
              </div>
            </div>

            <div class="illustration-reserve" aria-hidden="true">
              <span></span>
              <span></span>
              <span></span>
            </div>
          </div>

        </div>
      </section>

      <section class="match-section" id="match-console" aria-labelledby="match-section-title">
        <div class="match-copy">
          <p class="section-kicker">Opportunity Search</p>
          <h2 id="match-section-title">Find programs that fit your profile</h2>
          <p>
            Search competitions, scholarships, internships, summer schools, and courses from one focused Mentoria workspace.
          </p>
        </div>

        <div class="match-console match-console-dock" aria-labelledby="console-title">
          <div class="console-core">
            <div class="console-frame" aria-hidden="true"></div>
            <header class="console-header">
              <div>
                <h2 id="console-title">Opportunity Search</h2>
              </div>
            </header>
            <div class="showcase-search" aria-label="Search query">
              <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path d="M10.8 18.2a7.4 7.4 0 1 1 0-14.8 7.4 7.4 0 0 1 0 14.8Zm5.2-1.4 4.2 4.2" />
              </svg>
              <span>physics competitions</span>
            </div>

            <div class="criteria-grid" aria-label="Selected opportunity filters">
              <div class="criteria-select">
                <span class="criteria-label">Direction</span>
                <span class="criteria-value">Physics</span>
              </div>
              <div class="criteria-select">
                <span class="criteria-label">Format</span>
                <span class="criteria-value">Any</span>
              </div>
              <div class="criteria-select">
                <span class="criteria-label">Location</span>
                <span class="criteria-value">Global</span>
              </div>
              <div class="criteria-select">
                <span class="criteria-label">Grade</span>
                <span class="criteria-value">Grade 10</span>
              </div>
              <div class="criteria-select">
                <span class="criteria-label">Type</span>
                <span class="criteria-value">Competition</span>
              </div>
            </div>

            <div class="result-panel" aria-label="Opportunity showcase">
              <p class="result-heading">4 matched opportunities</p>
              <article class="opportunity-row">
                <h3>Almaty Physics Battles  2026</h3>
                <p>
                  An international team-based  physics competition for secondary school students, held in Almaty, Kazakhstan.  Teams are selected for final offline stage through online stage.
                </p>
              </article>
              <article class="opportunity-row">
                <h3>International Young Physicists' Tournament 2026</h3>
                <p>
                  A team-based physics tournament for high school students, taking place July 5-12, 2026 in Zurich, Switzerland, with research, experiments, and scientific discussion.
                </p>
              </article>
              <article class="opportunity-row">
                <h3>Beamline for Schools 2026</h3>
                <p>
                  A CERN, DESY, and ELSA physics proposal competition where high-school teams design an experiment for a particle accelerator beamline.
                </p>
              </article>
              <article class="opportunity-row">
                <h3>Online Physics Olympiad Invitational 2026</h3>
                <p>
                  An online physics contest pathway with an invitational round held August 30-September 1 and international participation from physics students.
                </p>
              </article>
            </div>
          </div>
        </div>
      </section>

      <section class="next-preview" id="features" aria-label="Next section preview">
        <article>
          <span>Saved opportunities</span>
          <strong>Track programs, deadlines, and application status from one student dashboard.</strong>
        </article>
        <article id="courses">
          <span>Mentoria courses</span>
          <strong>SAT, IELTS, English, STEM, and admissions tracks continue the journey after discovery.</strong>
        </article>
        <article id="companion">
          <span>Companion support</span>
          <strong>MentorPet explains why an opportunity fits without replacing mentors.</strong>
        </article>
        <article id="mentors">
          <span>Human mentors</span>
          <strong>Students can still ask for mentor help when an application needs judgment.</strong>
        </article>
      </section>
    </main>
  </body>
</html>

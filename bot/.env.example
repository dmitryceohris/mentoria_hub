# Telegram bot token from BotFather — keep secret, never commit the real value
BOT_TOKEN=123456:your-bot-token

# Comma-separated Telegram user IDs allowed to use admin commands (/broadcast, /raffle)
ADMIN_IDS=123456789

# Supabase — use the SERVICE ROLE key (server-side only, bypasses RLS). Never expose in the frontend.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Where to read opportunities from. If set, fetched over HTTP (e.g. your Vercel deploy);
# otherwise the local ../public/recsys/opportunities.json is used.
OPPORTUNITIES_URL=

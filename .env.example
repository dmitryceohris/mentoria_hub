VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key
# Legacy fallback only. Prefer VITE_SUPABASE_PUBLISHABLE_KEY for new deployments.
VITE_SUPABASE_ANON_KEY=

# Vercel:
# Add VITE_SUPABASE_URL and VITE_SUPABASE_PUBLISHABLE_KEY to the Vercel project
# environment variables for Production, Preview, and Development as needed.
# Do not add SUPABASE_SERVICE_ROLE_KEY or any other secret/server key to VITE_ env vars.

# Supabase Auth URL Configuration:
# Site URL should be the production Vercel domain.
# Redirect URLs should include:
# - http://localhost:5173/onboarding
# - https://your-production-domain/onboarding
# - https://*.vercel.app/onboarding, if Vercel preview deployments are used.
